---
import Layout from "../layouts/Layout.astro";
import { AudioOptimizer } from "../components/audio/AudioOptimizer";
---

<Layout title="Audio Optimizer" description="Convert and compress audio to MP3, OGG, AAC, or OPUS. Control bitrate and sample rate — all in your browser, no uploads required.">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Audio Optimizer</h1>
      <p class="mt-1 text-muted-foreground">
        Convert and compress audio files directly in your browser.
      </p>
    </div>
    <AudioOptimizer client:load />
  </div>
</Layout>
