---
import Layout from "../layouts/Layout.astro";
import { ImageOptimizer } from "../components/image/ImageOptimizer";
---

<Layout title="Image Optimizer">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Image Optimizer</h1>
      <p class="mt-1 text-muted-foreground">
        Convert and compress images directly in your browser.
      </p>
    </div>
    <ImageOptimizer client:load />
  </div>
</Layout>
